# Miniventure RPG — copie este arquivo para .env e ajuste os valores.
# settings.json foi removido; .env é a única fonte de configuração (host-controlled).

# URL do endpoint OpenAI-compatible (v1/chat/completions). Ex: http://localhost:3123/v1/chat/completions
AI_API_URL=http://localhost:3123/v1/chat/completions

# Chave de API do.endpoint. Para vLLM local pode ser qualquer string nao-vazia.
AI_API_KEY=your-api-key-here

# Nome do modelo no endpoint. Ex: AgentBridge, nemotron, Qwen3, DeepSeek-R1
AI_MODEL=AgentBridge

# Max tokens da resposta. Inteiro. Recomendado: 1000-4000. Default: 2000
AI_MAX_TOKENS=2000

# Temperatura da geração. Float 0.0 a 2.0. Mais baixo = determinístico, mais alto = criativo. Default: 0.8
AI_TEMPERATURE=0.8

# Timeout em segundos para chamadas à IA. Inteiro 30-600. Default: 120
AI_TIMEOUT=120

# Desativar thinking/reasoning do modelo. Valores aceitos: true | false. Ignorado se o modelo não suportar. Default: false
AI_DISABLE_THINKING=false

# Tamanho da narrativa das cenas. Valores aceitos: small | medium | large | unlimited. Default: unlimited
SCENE_SIZE=unlimited

# Chave secreta do Flask (sessions). Troque por uma string aleatória em produção.
SECRET_KEY=miniventure-rpg-secret-key-change-me
